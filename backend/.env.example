# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/general_store

# JWT
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - the origin your React dev server runs on
FRONTEND_ORIGIN=http://localhost:5173

# Flutterwave (get these from your Flutterwave dashboard: Settings -> API Keys)
# Only the SECRET key goes here (backend). The PUBLIC key goes in frontend/.env
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key_here
